# Copy to .env and edit locally. Never commit .env (see .gitignore).
#
# Special characters in VNC_PASSWORD must be quoted, e.g.:
#   VNC_PASSWORD="my-secret-here"

VNC_PASSWORD=change-me

# --- Tickmill (profile tickmill) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Tickmill-Demo
# RPYC_PORT=18812
# NT5_WS_URL=ws://host.docker.internal:8765/mt5-feed
# NT5_WS_SYMBOLS=BTCUSD

# --- XP / B3 (profile xp) — optional placeholders, login is manual via VNC ---
MT5_LOGIN_XP=
MT5_PASSWORD_XP=
MT5_SERVER_XP=XPMT5-DEMO
# RPYC_PORT_XP=18813
# NT5_WS_URL_XP=ws://host.docker.internal:8766/mt5-feed
# NT5_WS_SYMBOLS_XP=WDOQ26

# --- MT5 lifecycle (defaults shown) ---
# RESET_WINEPREFIX=0
# INSTALL_MT5=0
# RUN_MT5=1
# MT5_INSTALL_MODE=manual

# --- Automation on each start (RUN_MT5=1) ---
# DEPLOY_MQL5=1
# CONFIGURE_NT5=1
# BOOTSTRAP_PYTHON=1
# RUN_BRIDGE=1
# BRIDGE_WAIT_SECONDS=180
# NT5_SERVICE_ENABLED=0   # keep 0 until WebRequest whitelist is done (see docs/MANUAL_STEPS.md)
